# Copy to .env.local and fill in with real values (never commit .env.local).
# VITE_SUPABASE_URL is backend/.env's SUPABASE_PUBLIC_URL.
# VITE_SUPABASE_ANON_KEY is backend/.env's SUPABASE_PUBLISHABLE_KEY (from `sh run.sh secrets`).
# Leave both unset for a no-backend, local-only build.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
