# Cross-origin isolation: required for SharedArrayBuffer, which the multi-threaded
# Stockfish build needs. Must cover the document and every worker script (dev/preview
# set the same headers via vite.config.ts).
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

/exercises-manifest.json
  Cache-Control: no-cache

# Service worker updates must reach clients promptly — never cache the script
/sw.js
  Cache-Control: no-cache

/data/*
  Cache-Control: public, max-age=31536000, immutable

# The engine lives under a content-hashed directory (/engines/<version>/…) — the splat
# spans slashes, so it covers the nested files. Never serve unversioned engine files
# under this rule: `immutable` is never revalidated, and a bad copy is then unfixable
# without the user clearing their site data (see ENGINE_ASSET_GENERATION in vite.config.ts).
/engines/*
  Cache-Control: public, max-age=31536000, immutable
